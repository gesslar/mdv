{
  "name": "mdv",
  "private": true,
  "version": "0.1.2",
  "type": "module",
  "scripts": {
    "tauri": "tauri",
    "build": "tauri build",
    "bundle": "NO_STRIP=true tauri bundle",
    "dist:rpm": "/projects/repos/rpm",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "update": "npx npm-check-updates -u && npm install",
    "pr": "gt submit --publish --restack --ai",
    "checkout": "$ELEVATOR && elevatePrivileges && NO_STRIP=true tauri build --bundles rpm && ./fix-desktop-file.sh && sudo dnf install -y src-tauri/target/release/bundle/rpm/mdv-0.1.2-1.x86_64.rpm && mdv && sudo dnf remove mdv -y",
    "patch": "npm version patch",
    "minor": "npm version minor",
    "major": "npm version major",
    "version": "bash scripts/sync-version.sh"
  },
  "devDependencies": {
    "@gesslar/uglier": "^2.2.0",
    "@highlightjs/cdn-assets": "^11.11.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@tauri-apps/cli": "^2.10.1",
    "dompurify": "^3.3.3",
    "eslint": "^10.0.3",
    "eslint-plugin-jsdoc": "^62.8.0",
    "globals": "^17.4.0",
    "marked": "^17.0.4",
    "marked-highlight": "^2.2.3"
  }
}
